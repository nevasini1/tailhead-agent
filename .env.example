# --- LLM agent (required for plan / open-unit) ---
# Pick one provider via LLM_PROVIDER: openai (default) | gemini | anthropic

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Google Gemini (AI Studio / Cloud API key): pip install -e ".[gemini]"
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Claude: pip install -e ".[anthropic]"
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: override the default system prompt with a file you maintain
# TRAILHEAD_AGENT_PROMPT_FILE=C:\path\to\prompt.txt

# --- Ranking pipeline (Pydantic; LangGraph orchestrator is always used) ---
# LLM_PLANNER_PHASE=0   # 1 = extra LLM call for brief planner notes before ranking
# LLM_RANKING_REPAIR=1   # 0 = disable second LLM pass on schema / allowlist mismatch
# LLM_OPENAI_STRICT_SCHEMA=0  # 1 = OpenAI only: response_format json_schema strict from Pydantic

# --- What to crawl (required for plan / open-unit) ---
TRAILHEAD_START_URL=
# Natural-language instructions for the LLM (no keyword YAML)
TRAILHEAD_INTENT=

# --- Browser / discovery tuning ---
# TRAILHEAD_ALLOWED_HOST=trailhead.salesforce.com
# TRAILHEAD_MAX_MODULES=15
# TRAILHEAD_PAGE_SETTLE_MS=3500
# Extra scroll rounds to surface lazy-loaded module/unit links (0-20, default 4). Empty discovery raises DiscoveryError with hints.
# TRAILHEAD_DISCOVERY_SCROLL_ROUNDS=4
# Max clicks on Load more / Show more style controls before scraping (0-24, default 8). Set 0 to disable.
# TRAILHEAD_DISCOVERY_PAGINATION_CLICKS=8
# Playwright goto wait: domcontentloaded (default) | load | commit
# TRAILHEAD_DISCOVERY_NAV_WAIT_UNTIL=domcontentloaded

# --- Login (optional) ---
TRAILHEAD_EMAIL=
TRAILHEAD_PASSWORD=
TRAILHEAD_BROWSER_USER_DATA_DIR=

AGENT_ACTION_DELAY_MS=0
# TRAILHEAD_AGENT_HEADLESS=1
# After navigation while recording: wait up to N ms for main/article/shell (locator wait, not blind sleep). 0 = skip.
# TRAILHEAD_SHELL_WAIT_TIMEOUT_MS=12000
# Extra Chromium flags for CI/containers (comma-separated), e.g. --disable-dev-shm-usage
# TRAILHEAD_CHROMIUM_EXTRA_ARGS=
# When recording (TRAILHEAD_RECORD_VIDEO_DIR or plan --artifacts-dir): auto headed Chromium + Playwright slow_mo + 1440x900-style viewport + small action delay (better demos). CI: TRAILHEAD_RECORDING_DEMO_AUTO=0 or plan --no-recording-demo-browser
# TRAILHEAD_RECORDING_DEMO_AUTO=1
# Verbose stderr narration: CLI inputs, recording prefs, discovery sample, each LangGraph step, final ranked list. Tests default to 0 via tests/conftest.py; CI: TRAILHEAD_DEMO_NARRATION=0
# TRAILHEAD_DEMO_NARRATION=1
# TRAILHEAD_DEMO_SLOW_MO_MS=65
# TRAILHEAD_DEMO_VIEWPORT_WIDTH=1440
# TRAILHEAD_DEMO_VIEWPORT_HEIGHT=900
# Save a Playwright .webm of the browser session (directory is created if missing).
# With this set, `plan` / `open-unit` also write e2e-plan-*.json (and *-latest.json) here with stdout-equivalent output + video file listing.
# Easier: `trailhead-agent plan --save-e2e` or `--artifacts-dir ./my-run` (no env needed).
# TRAILHEAD_RECORD_VIDEO_DIR=./artifacts/demo-video
# While recording: smooth scroll so the .webm is not a single static frame (set 0 to disable)
# TRAILHEAD_VIDEO_SCROLL_DEMO=1
# Try to scroll Launch / Playground / hands-on controls into view (Trailhead DOM; log in for best results). 0 = disable.
# TRAILHEAD_RECORDING_PLAYGROUND_CTA_SCROLL=1
# Extra ms to wait at bottom of page during recording scroll (lazy LWCs)
# TRAILHEAD_RECORDING_SCROLL_BOTTOM_MS=2800
# While recording: full-screen HTML slides label phases (discovery, LLM rank, ranked walk, org prepare). On by default when video dir is set; set 0 to disable.
# TRAILHEAD_DEMO_TITLECARDS=0
# TRAILHEAD_DEMO_TITLECARD_MS=2800
# Max units listed on Phase 3 LLM ranking title card (3–80)
# TRAILHEAD_DEMO_TITLECARD_RANK_MAX=18
# Closing slide after the live Trailhead segment (plan vs org); shorter than phase slides.
# TRAILHEAD_DEMO_END_CARD_MS=2400
# Rename Playwright hash .webm files to plan-primary.webm / org-prepare.webm / open-unit-primary.webm (default on).
# TRAILHEAD_E2E_FRIENDLY_VIDEO_NAMES=0
# Write e2e-report.html (video grid + manifest timeline) in the artifacts dir. Set 0 to skip.
# TRAILHEAD_E2E_HTML_REPORT=0

# --- Production tuning ---
# TRAILHEAD_LOG_LEVEL=INFO
# LLM_MAX_RETRIES=4
# LLM_RETRY_MIN_WAIT_S=1
# LLM_RETRY_MAX_WAIT_S=30
# LLM_HTTP_TIMEOUT_S=120

# Org prepare --open-playground: when recording video, minimum ms to wait on Trailhead after load (plus scroll demo).
# Increase if .webm still looks blank; decrease for faster CI (0 allowed).
# TRAILHEAD_ORG_PREPARE_RECORDING_MIN_MS=5500

# After plan title cards (and optional --walk-ranked), return to the module URL and dwell so plan-primary.webm does not end on a blank title slide only.
# TRAILHEAD_PLAN_RECORDING_TAIL_MIN_MS=5500

# --- Org / Salesforce CLI (trailhead-agent org *) ---
# TRAILHEAD_ORG_EXECUTOR=noop   # noop (default) | cli — use CliOrgExecutor for sf org display / deploy steps
# TRAILHEAD_SF_ORG_ALIAS=       # Default --target-org for sf commands (safe characters only)
# TRAILHEAD_ORG_PROJECT_DIR=    # Optional default SFDX project for sf_deploy verification steps
# TRAILHEAD_ORG_CHECKLISTS_FILE=  # Override path to org_checklists.yaml
# TRAILHEAD_PLAYGROUND_OPEN=1   # 0 disables browser navigation in `org prepare --open-playground`
