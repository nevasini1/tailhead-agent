# --- LLM agent (required for plan / open-unit) ---
# Pick one provider via LLM_PROVIDER: openai (default) | gemini | anthropic

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Google Gemini (AI Studio / Cloud API key): pip install -e ".[gemini]"
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Claude: pip install -e ".[anthropic]"
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: override the default system prompt with a file you maintain
# TRAILHEAD_AGENT_PROMPT_FILE=C:\path\to\prompt.txt

# --- Ranking pipeline (Pydantic; LangGraph orchestrator is always used) ---
# LLM_PLANNER_PHASE=0   # 1 = extra LLM call for brief planner notes before ranking
# LLM_RANKING_REPAIR=1   # 0 = disable second LLM pass on schema / allowlist mismatch
# LLM_OPENAI_STRICT_SCHEMA=0  # 1 = OpenAI only: response_format json_schema strict from Pydantic

# --- What to crawl (required for plan / open-unit) ---
TRAILHEAD_START_URL=
# Natural-language instructions for the LLM (no keyword YAML)
TRAILHEAD_INTENT=

# --- Browser / discovery tuning ---
# TRAILHEAD_ALLOWED_HOST=trailhead.salesforce.com
# TRAILHEAD_MAX_MODULES=15
# TRAILHEAD_PAGE_SETTLE_MS=3500
# Extra scroll rounds to surface lazy-loaded module/unit links (0-20, default 4). Empty discovery raises DiscoveryError with hints.
# TRAILHEAD_DISCOVERY_SCROLL_ROUNDS=4

# --- Login (optional) ---
TRAILHEAD_EMAIL=
TRAILHEAD_PASSWORD=
TRAILHEAD_BROWSER_USER_DATA_DIR=

AGENT_ACTION_DELAY_MS=0
# TRAILHEAD_AGENT_HEADLESS=1
# Save a Playwright .webm of the browser session (directory is created if missing).
# With this set, `plan` / `open-unit` also write e2e-plan-*.json (and *-latest.json) here with stdout-equivalent output + video file listing.
# Easier: `trailhead-agent plan --save-e2e` or `--artifacts-dir ./my-run` (no env needed).
# TRAILHEAD_RECORD_VIDEO_DIR=./artifacts/demo-video
# While recording: smooth scroll so the .webm is not a single static frame (set 0 to disable)
# TRAILHEAD_VIDEO_SCROLL_DEMO=1
# While recording: full-screen HTML slides label phases (discovery, LLM rank, ranked walk, org prepare). On by default when video dir is set; set 0 to disable.
# TRAILHEAD_DEMO_TITLECARDS=0
# TRAILHEAD_DEMO_TITLECARD_MS=2800

# --- Production tuning ---
# TRAILHEAD_LOG_LEVEL=INFO
# LLM_MAX_RETRIES=4
# LLM_RETRY_MIN_WAIT_S=1
# LLM_RETRY_MAX_WAIT_S=30
# LLM_HTTP_TIMEOUT_S=120

# --- Org / Salesforce CLI (trailhead-agent org *) ---
# TRAILHEAD_ORG_EXECUTOR=noop   # noop (default) | cli — use CliOrgExecutor for sf org display / deploy steps
# TRAILHEAD_SF_ORG_ALIAS=       # Default --target-org for sf commands (safe characters only)
# TRAILHEAD_ORG_PROJECT_DIR=    # Optional default SFDX project for sf_deploy verification steps
# TRAILHEAD_ORG_CHECKLISTS_FILE=  # Override path to org_checklists.yaml
# TRAILHEAD_PLAYGROUND_OPEN=1   # 0 disables browser navigation in `org prepare --open-playground`
